{
  "name": "entregai-print-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Entregaí Print Agent",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "node scripts/check.js",
    "dist:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-log": "^5.4.3"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "br.com.entregaiapp.printagent",
    "productName": "Entregaí Print Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
