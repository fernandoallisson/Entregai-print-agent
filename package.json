{
  "name": "entregai-print-agent",
  "version": "2.3.0",
  "private": true,
  "description": "Entregaí Print Agent",
  "author": "Entregaí",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "node scripts/check.js",
    "test": "node --test tests/*.test.js",
    "dist:win": "electron-builder --win nsis --publish never && node scripts/normalize-update-metadata.js",
    "release:validate": "node scripts/validate-release.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.8",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "br.com.entregaiapp.printagent",
    "productName": "Entregaí Print Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "build/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "fernandoallisson",
        "repo": "Entregai-print-agent",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "entregai-print-agent-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp",
      "shortcutName": "Entregaí Print Agent",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
