# Desenvolvimento local:
# - use http://localhost:3010/api quando o backend estiver rodando na mesma máquina.
#
# Aplicativo instalado:
# - crie um arquivo .env ao lado do executável do Entregaí Print Agent com estas mesmas variáveis,
#   ou configure estas variáveis no Windows antes de abrir o aplicativo.
#
# Produção:
# - substitua pelo endereço público HTTPS do backend, mantendo o /api no final.
ENTREGAI_API_BASE_URL=http://localhost:3010/api
ENTREGAI_AGENT_ENVIRONMENT=development
