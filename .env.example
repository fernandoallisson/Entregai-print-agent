# Estas variáveis são opcionais e mantidas apenas para compatibilidade e desenvolvimento.
# No aplicativo instalado, use o botão "Configurar conexão". Os valores salvos na
# interface têm prioridade e dispensam a criação de um arquivo .env.
# Em produção, use o endereço público HTTPS do backend, mantendo o /api no final.
ENTREGAI_API_BASE_URL=http://localhost:3010/api
ENTREGAI_AGENT_ENVIRONMENT=development

# auto tenta o Supabase Realtime e usa polling como contingência.
# Use polling apenas para rollback controlado.
ENTREGAI_PRINT_TRANSPORT=auto

# Exclusivo para testes locais não empacotados. O instalador ignora esta variável
# e mantém 180000 ms (3 minutos). O menor valor local permitido é 3000 ms.
ENTREGAI_POLLING_INTERVAL_MS=3000
